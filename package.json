{
  "name": "@aozi6666/bee-design",
  "private": false,
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aozi6666/Bee-Design.git"
  },
  "homepage": "https://github.com/aozi6666/Bee-Design",
  "bugs": {
    "url": "https://github.com/aozi6666/Bee-Design/issues"
  },
  "type": "module",
  "files": [
    "build",
    "README.md"
  ],
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "dev": "vite",
    "clean": "rimraf ./build",
    "lint": "eslint --ext js,ts,tsx src --max-warnings 5",
    "lint:fix": "npm run lint -- --fix",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint:fix": "npm run stylelint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:staged": "lint-staged",
    "build": "npm run clean && npm run build-ts && npm run build-css",
    "build-ts": "tsc -p tsconfig.build.json",
    "build-css": "sass ./src/styles/index.scss ./build/index.css",
    "build:bundle": "rimraf ./dist && npm run build:bundle:esm && npm run build:bundle:umd",
    "build:bundle:esm": "rollup -c rollup/rollup.esm.config.js",
    "build:bundle:umd": "rollup -c rollup/rollup.umd.config.js",
    "webpack:dev": "webpack",
    "webpack:build": "NODE_ENV=production webpack",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build:site": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:ci": "cross-env CI=true jest",
    "prepublishOnly": "npm run test:ci && npm run lint && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "axios": "^1.13.6",
    "classnames": "^2.5.1",
    "cross-env": "^10.1.0",
    "lodash": "^4.17.23",
    "react-transition-group": "^4.4.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-commonjs": "^26.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-onboarding": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/classnames": "^2.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.17",
    "globals": "^16.5.0",
    "html-webpack-plugin": "^5.6.6",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss-scss": "^4.0.9",
    "prettier": "3.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.30.0",
    "rollup-plugin-exclude-dependencies-from-bundle": "^1.1.24",
    "rollup-plugin-sass": "^1.12.24",
    "rollup-plugin-typescript2": "^0.36.0",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "storybook": "^10.2.17",
    "style-loader": "^4.0.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^35.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-scss": "^7.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  }
}
