{
  "name": "bee-design-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "lint": "eslint --ext js,ts,tsx packages apps --max-warnings 5",
    "lint:fix": "pnpm lint -- --fix",
    "stylelint": "stylelint \"packages/**/*.{css,scss}\" \"apps/**/*.{css,scss}\"",
    "stylelint:fix": "pnpm stylelint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:staged": "lint-staged",
    "components:build": "pnpm -C packages/components build",
    "components:test": "pnpm -C packages/components test",
    "components:test:ci": "pnpm -C packages/components test:ci",
    "components:typecheck": "pnpm -C packages/components typecheck",
    "components:lint": "pnpm -C packages/components lint",
    "utils:build": "pnpm -C packages/utils build",
    "utils:typecheck": "pnpm -C packages/utils typecheck",
    "docs:dev": "pnpm -C apps/docs-site storybook",
    "docs:build": "pnpm -C apps/docs-site build-storybook",
    "turbo:build": "turbo run build",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:lint": "turbo run lint",
    "turbo:test": "turbo run test",
    "release": "pnpm components:typecheck && pnpm components:test:ci && pnpm components:lint && pnpm components:build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-commonjs": "^26.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-onboarding": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/classnames": "^2.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.2.17",
    "globals": "^16.5.0",
    "html-webpack-plugin": "^5.6.6",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss-scss": "^4.0.9",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.30.0",
    "rollup-plugin-exclude-dependencies-from-bundle": "^1.1.24",
    "rollup-plugin-sass": "^1.12.24",
    "rollup-plugin-typescript2": "^0.36.0",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "storybook": "^10.2.17",
    "style-loader": "^4.0.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^35.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-scss": "^7.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "tslib": "^2.8.1",
    "turbo": "^2.8.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.3"
  }
}
